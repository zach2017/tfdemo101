# Copy to terraform.tfvars (gitignored) and adjust. The GitHub Actions pipeline
# instead reads values from repository variables/secrets — see the README.

aws_region         = "us-east-1"
project_name       = "eks-platform"
environment        = "dev"
kubernetes_version = "1.30"

vpc_cidr                 = "10.0.0.0/16"
availability_zones_count = 3

system_node_instance_types = ["t3.medium"]
system_node_desired_size   = 2
system_node_min_size       = 1
system_node_max_size       = 3

# Lock the public endpoint down to known IPs. Example only:
endpoint_public_access       = true
endpoint_public_access_cidrs = ["203.0.113.10/32"]

# IAM roles (besides the pipeline) that should be cluster admins:
cluster_admin_role_arns = [
  # "arn:aws:iam::123456789012:role/PlatformAdmins"
]
